// Grafana Alloy configuration for scraping the Infinite Campus exporter

prometheus.scrape "ic_campus" {
  targets = [{
    __address__ = "localhost:9877",
  }]

  scrape_interval = "5m"
  scrape_timeout  = "30s"
  job_name        = "ic_campus_exporter"

  forward_to = [prometheus.remote_write.default.receiver]
}

prometheus.remote_write "default" {
  endpoint {
    url = "http://prometheus:9090/api/v1/write"

    // If using Grafana Cloud, replace with your push URL and credentials:
    // url = "https://prometheus-prod-XX-prod-XX.grafana.net/api/prom/push"
    // basic_auth {
    //   username = env("GRAFANA_CLOUD_USER")
    //   password = env("GRAFANA_CLOUD_API_KEY")
    // }
  }
}
