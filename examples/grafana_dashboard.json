{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" },
    { "type": "panel", "id": "stat", "name": "Stat", "version": "" },
    { "type": "panel", "id": "table", "name": "Table", "version": "" },
    { "type": "panel", "id": "barchart", "name": "Bar chart", "version": "" },
    { "type": "panel", "id": "text", "name": "Text", "version": "" }
  ],
  "annotations": { "list": [] },
  "description": "Infinite Campus student grades and assignment tracker",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "⚠️ Alerts",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [
            { "options": { "0": { "color": "green", "index": 0, "text": "None" } }, "type": "value" }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          },
          "unit": "short",
          "noValue": "0"
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 1 },
      "id": 1,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto",
        "wideLayout": true
      },
      "title": "Missing Assignments (All Time)",
      "type": "stat",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum(ic_assignment_flag{student_name=~\"$student\", flag=\"missing\"}) or vector(0)",
          "instant": true,
          "legendFormat": "Missing",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [
            { "options": { "0": { "color": "green", "index": 0, "text": "None" } }, "type": "value" }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 1 }
            ]
          },
          "unit": "short",
          "noValue": "0"
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 1 },
      "id": 2,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto",
        "wideLayout": true
      },
      "title": "Late Assignments",
      "type": "stat",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum(ic_assignment_flag{student_name=~\"$student\", flag=\"late\"} and on(assignment_name, course_name, student_name, student_id) ic_assignment_due_date_timestamp{student_name=~\"$student\"} > (time() - $weeks * 604800)) or vector(0)",
          "instant": true,
          "legendFormat": "Late",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": 60 },
              { "color": "yellow", "value": 70 },
              { "color": "green", "value": 80 }
            ]
          },
          "unit": "percent",
          "min": 0,
          "max": 100,
          "noValue": "N/A"
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 1 },
      "id": 3,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto",
        "wideLayout": true
      },
      "title": "Overall Average Score",
      "type": "stat",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "avg(ic_assignment_score_percentage{student_name=~\"$student\"} and on(assignment_name, course_name, student_name, student_id) ic_assignment_due_date_timestamp{student_name=~\"$student\"} > (time() - $weeks * 604800))",
          "instant": true,
          "legendFormat": "Avg Score",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 1 }
            ]
          },
          "unit": "short",
          "noValue": "0"
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 1 },
      "id": 4,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto",
        "wideLayout": true
      },
      "title": "Incomplete Assignments",
      "type": "stat",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum(ic_assignment_flag{student_name=~\"$student\", flag=\"incomplete\"} and on(assignment_name, course_name, student_name, student_id) ic_assignment_due_date_timestamp{student_name=~\"$student\"} > (time() - $weeks * 604800)) or vector(0)",
          "instant": true,
          "legendFormat": "Incomplete",
          "refId": "A"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "id": 101,
      "title": "Grades by Course",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": 60 },
              { "color": "yellow", "value": 70 },
              { "color": "green", "value": 80 }
            ]
          },
          "unit": "percent",
          "min": 0,
          "max": 100
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 6 },
      "id": 5,
      "options": {
        "barRadius": 0.05,
        "barWidth": 0.7,
        "fullHighlight": false,
        "groupWidth": 0.7,
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": false },
        "orientation": "horizontal",
        "showValue": "always",
        "stacking": "none",
        "tooltip": { "mode": "single", "sort": "none" },
        "xTickLabelRotation": 0,
        "xTickLabelSpacing": 100,
        "colorByField": "Value"
      },
      "title": "Average Score by Course",
      "type": "barchart",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "avg by (course_name) (ic_assignment_score_percentage{student_name=~\"$student\"} and on(assignment_name, course_name, student_name, student_id) ic_assignment_due_date_timestamp{student_name=~\"$student\"} > (time() - $weeks * 604800))",
          "instant": true,
          "legendFormat": "{{course_name}}",
          "refId": "A"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 },
      "id": 102,
      "title": "Missing Assignments Detail",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "red" },
          "custom": {
            "align": "auto",
            "cellOptions": { "type": "color-background" },
            "filterable": true,
            "inspect": false
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "red", "value": null }]
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Course" },
            "properties": [{ "id": "custom.width", "value": 200 }]
          },
          {
            "matcher": { "id": "byName", "options": "Assignment" },
            "properties": [{ "id": "custom.width", "value": 300 }]
          },
          {
            "matcher": { "id": "byName", "options": "Missing" },
            "properties": [
              { "id": "custom.width", "value": 80 },
              { "id": "custom.hidden", "value": true }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Days Overdue" },
            "properties": [
              { "id": "custom.width", "value": 120 },
              { "id": "unit", "value": "d" },
              { "id": "decimals", "value": 0 },
              { "id": "custom.cellOptions", "value": { "type": "color-background" } },
              { "id": "color", "value": { "mode": "thresholds" } },
              { "id": "thresholds", "value": {
                  "mode": "absolute",
                  "steps": [
                    { "color": "yellow", "value": null },
                    { "color": "orange", "value": 7 },
                    { "color": "red", "value": 14 }
                  ]
                }
              }
            ]
          }
        ]
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 15 },
      "id": 6,
      "options": {
        "cellHeight": "sm",
        "footer": { "countRows": false, "fields": "", "reducer": ["sum"], "show": false },
        "showHeader": true,
        "sortBy": [{ "desc": false, "displayName": "Course" }]
      },
      "title": "Missing Assignments (All Time)",
      "type": "table",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "ic_assignment_flag{student_name=~\"$student\", flag=\"missing\"} == 1",
          "instant": true,
          "legendFormat": "__auto",
          "refId": "A",
          "format": "table"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "(time() - ic_assignment_due_date_timestamp{student_name=~\"$student\"}) / 86400 and on(assignment_name, course_name, student_name, student_id) ic_assignment_flag{student_name=~\"$student\", flag=\"missing\"} == 1",
          "instant": true,
          "legendFormat": "__auto",
          "refId": "B",
          "format": "table"
        }
      ],
      "transformations": [
        {
          "id": "joinByField",
          "options": { "byField": "assignment_name", "mode": "outer" }
        },
        {
          "id": "filterFieldsByName",
          "options": {
            "include": { "names": ["course_name", "assignment_name", "Value #A", "Value #B"] }
          }
        },
        {
          "id": "organize",
          "options": {
            "renameByName": {
              "course_name": "Course",
              "assignment_name": "Assignment",
              "Value #A": "Missing",
              "Value #B": "Days Overdue"
            }
          }
        },
        { "id": "sortBy", "options": { "fields": [{ "desc": true, "displayName": "Days Overdue" }] } }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 23 },
      "id": 103,
      "title": "All Assignments",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "custom": {
            "align": "auto",
            "cellOptions": { "type": "auto" },
            "filterable": true,
            "inspect": false
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 80 }
            ]
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "course_name" },
            "properties": [
              { "id": "displayName", "value": "Course" },
              { "id": "custom.width", "value": 180 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "assignment_name" },
            "properties": [
              { "id": "displayName", "value": "Assignment" },
              { "id": "custom.width", "value": 280 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Score %" },
            "properties": [
              { "id": "custom.width", "value": 100 },
              { "id": "unit", "value": "percent" },
              { "id": "custom.cellOptions", "value": { "type": "color-background", "mode": "gradient" } },
              { "id": "color", "value": { "mode": "thresholds" } },
              { "id": "thresholds", "value": {
                  "mode": "absolute",
                  "steps": [
                    { "color": "red", "value": null },
                    { "color": "orange", "value": 60 },
                    { "color": "yellow", "value": 70 },
                    { "color": "green", "value": 80 }
                  ]
                }
              }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Points" },
            "properties": [{ "id": "custom.width", "value": 80 }]
          },
          {
            "matcher": { "id": "byName", "options": "Total Pts" },
            "properties": [{ "id": "custom.width", "value": 80 }]
          },
          {
            "matcher": { "id": "byName", "options": "Missing" },
            "properties": [
              { "id": "custom.width", "value": 75 },
              { "id": "custom.cellOptions", "value": { "type": "color-background" } },
              { "id": "color", "value": { "mode": "thresholds" } },
              { "id": "thresholds", "value": {
                  "mode": "absolute",
                  "steps": [
                    { "color": "green", "value": null },
                    { "color": "red", "value": 1 }
                  ]
                }
              },
              { "id": "mappings", "value": [
                  { "options": { "0": { "text": "" }, "1": { "text": "MISSING" } }, "type": "value" }
                ]
              }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Late" },
            "properties": [
              { "id": "custom.width", "value": 60 },
              { "id": "custom.cellOptions", "value": { "type": "color-background" } },
              { "id": "color", "value": { "mode": "thresholds" } },
              { "id": "thresholds", "value": {
                  "mode": "absolute",
                  "steps": [
                    { "color": "transparent", "value": null },
                    { "color": "orange", "value": 1 }
                  ]
                }
              },
              { "id": "mappings", "value": [
                  { "options": { "0": { "text": "" }, "1": { "text": "LATE" } }, "type": "value" }
                ]
              }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Turned In" },
            "properties": [
              { "id": "custom.width", "value": 80 },
              { "id": "mappings", "value": [
                  { "options": { "0": { "text": "" }, "1": { "text": "Yes" } }, "type": "value" }
                ]
              }
            ]
          }
        ]
      },
      "gridPos": { "h": 16, "w": 24, "x": 0, "y": 24 },
      "id": 7,
      "options": {
        "cellHeight": "sm",
        "footer": { "countRows": false, "fields": "", "reducer": ["sum"], "show": false },
        "showHeader": true,
        "sortBy": [{ "desc": false, "displayName": "Course" }]
      },
      "title": "All Assignments",
      "type": "table",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "ic_assignment_score_percentage{student_name=~\"$student\"} and on(assignment_name, course_name, student_name, student_id) ic_assignment_due_date_timestamp{student_name=~\"$student\"} > (time() - $weeks * 604800)",
          "instant": true,
          "legendFormat": "__auto",
          "refId": "A",
          "format": "table"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "ic_assignment_score_points{student_name=~\"$student\"} and on(assignment_name, course_name, student_name, student_id) ic_assignment_due_date_timestamp{student_name=~\"$student\"} > (time() - $weeks * 604800)",
          "instant": true,
          "legendFormat": "__auto",
          "refId": "B",
          "format": "table"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "ic_assignment_total_points{student_name=~\"$student\"} and on(assignment_name, course_name, student_name, student_id) ic_assignment_due_date_timestamp{student_name=~\"$student\"} > (time() - $weeks * 604800)",
          "instant": true,
          "legendFormat": "__auto",
          "refId": "C",
          "format": "table"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "ic_assignment_flag{student_name=~\"$student\", flag=\"missing\"}",
          "instant": true,
          "legendFormat": "__auto",
          "refId": "D",
          "format": "table"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "ic_assignment_flag{student_name=~\"$student\", flag=\"late\"} and on(assignment_name, course_name, student_name, student_id) ic_assignment_due_date_timestamp{student_name=~\"$student\"} > (time() - $weeks * 604800)",
          "instant": true,
          "legendFormat": "__auto",
          "refId": "E",
          "format": "table"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "ic_assignment_flag{student_name=~\"$student\", flag=\"turnedin\"} and on(assignment_name, course_name, student_name, student_id) ic_assignment_due_date_timestamp{student_name=~\"$student\"} > (time() - $weeks * 604800)",
          "instant": true,
          "legendFormat": "__auto",
          "refId": "F",
          "format": "table"
        }
      ],
      "transformations": [
        {
          "id": "joinByField",
          "options": { "byField": "assignment_name", "mode": "outer" }
        },
        {
          "id": "filterFieldsByName",
          "options": {
            "include": {
              "pattern": "^(course_name|assignment_name|Value A|Value B|Value C|Value D|Value E|Value F)$"
            }
          }
        },
        {
          "id": "organize",
          "options": {
            "renameByName": {
              "course_name": "Course",
              "assignment_name": "Assignment",
              "Value A": "Score %",
              "Value B": "Points",
              "Value C": "Total Pts",
              "Value D": "Missing",
              "Value E": "Late",
              "Value F": "Turned In"
            }
          }
        }
      ]
    }
  ],
  "refresh": "5m",
  "schemaVersion": 38,
  "tags": ["infinite-campus", "grades", "students"],
  "templating": {
    "list": [
      {
        "current": {},
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "definition": "label_values(ic_assignment_score_percentage, student_name)",
        "hide": 0,
        "includeAll": false,
        "multi": false,
        "name": "student",
        "options": [],
        "query": {
          "query": "label_values(ic_assignment_score_percentage, student_name)",
          "refId": "StandardVariableQuery"
        },
        "refresh": 2,
        "regex": "",
        "sort": 1,
        "label": "Student",
        "type": "query"
      },
      {
        "current": { "selected": true, "text": "8", "value": "8" },
        "hide": 0,
        "includeAll": false,
        "multi": false,
        "name": "weeks",
        "options": [
          { "selected": false, "text": "1", "value": "1" },
          { "selected": false, "text": "2", "value": "2" },
          { "selected": false, "text": "4", "value": "4" },
          { "selected": true,  "text": "8", "value": "8" },
          { "selected": false, "text": "12", "value": "12" },
          { "selected": false, "text": "26", "value": "26" },
          { "selected": false, "text": "52", "value": "52" }
        ],
        "query": "1,2,4,8,12,26,52",
        "label": "Look Back (weeks)",
        "type": "custom"
      }
    ]
  },
  "time": { "from": "now-6h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Infinite Campus - Student Grades",
  "uid": "ic-campus-grades",
  "version": 3
}
